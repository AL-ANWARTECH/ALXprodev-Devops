#!/bin/bash
# Extract Pokemon data
name=$(jq -r '.name' pikachu.json)
height=$(jq -r '.height' pikachu.json)
weight=$(jq -r '.weight' pikachu.json)
type=$(jq -r '.types[0].type.name' pikachu.json)

# Format height and weight
formatted_height=$(echo "scale=1; $height/10" | bc)
formatted_weight=$weight

# Output in required format
echo "$name is of type $type, weighs ${formatted_weight}kg, and is ${formatted_height}m tall."
