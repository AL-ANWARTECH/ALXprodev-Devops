#!/bin/bash

# Check if pikachu.json exists
if [ ! -f "pikachu.json" ]; then
    echo "Error: pikachu.json file not found!"
    exit 1
fi

# Extract data using jq, process with awk, and format with sed
jq -r '.name, .weight, .height, .types[0].type.name' pikachu.json | \
awk 'NR==1{name=$0} NR==2{weight=$0} NR==3{height=$0} NR==4{type=$0} END{printf "%s\n%s\n%s\n%s\n", name, weight, height, type}' | \
awk 'NR==1{name=$0} NR==2{weight=$0} NR==3{height=$0} NR==4{type=$0} END{printf "%s is of type %s, weighs %skg, and is %.1fm tall.\n", name, type, weight, height/10}' | \
sed 's/\b\(.\)/\u\1/'
